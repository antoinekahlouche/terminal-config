{
	"$schema": "https://opencode.ai/config.json",
	"agent": {
		"default": {
			"description": "General-purpose.",
			"mode": "subagent",
			"model": "openai/gpt-5.5",
			"reasoningEffort": "low",
			"prompt": "Execute the assigned task directly and verify the result. Do not delegate to another agent. Return concise findings or completed work to the parent agent.",
			"permission": {
				"task": "deny"
			}
		}
	},
	"permission": {
		"task": {
			"*": "deny",
			"default": "allow"
		}
	},
	"mcp": {
		"chrome-devtools": {
			"type": "local",
			"command": ["npx", "-y", "chrome-devtools-mcp@latest"],
			"enabled": true
		}
	}
}
