working-directory = ~/ws
confirm-close-surface = false
cursor-style = block
font-family = JetBrainsMono Nerd Font
font-size = 13
macos-option-as-alt = true
macos-titlebar-proxy-icon = hidden
shell-integration-features = no-cursor
theme = One Half Dark
window-colorspace = display-p3
window-padding-balance = true
window-padding-x = 5
window-padding-y = 5
window-save-state = always
window-width = 214
window-height = 63

macos-titlebar-style = tabs
# macos-non-native-fullscreen = padded-notch

# quick-terminal-animation-duration = 0
# quick-terminal-autohide = true
# quick-terminal-size = 100%,100%
# keybind = global:cmd+opt+ctrl+shift+space=toggle_quick_terminal

keybind = opt+1=goto_tab:1
keybind = opt+2=goto_tab:2
keybind = opt+3=goto_tab:3
keybind = opt+4=goto_tab:4
keybind = opt+5=goto_tab:5
keybind = opt+6=goto_tab:6
keybind = opt+7=goto_tab:7
keybind = opt+8=goto_tab:8
keybind = opt+9=goto_tab:9
